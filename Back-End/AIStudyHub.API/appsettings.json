{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=AIStudyHub;Trusted_Connection=True;TrustServerCertificate=True"
  },

  "Jwt": {
    "Issuer": "AIStudyHub",
    "Audience": "AIStudyHubClient",
    "SecretKey": "YourSuperSecretKeyThatIsAtLeast32Characters!!",
    "ExpirationMinutes": 60
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },

  "ExternalServices": {
    "OpenAI": {
      "ApiKey": "YOUR_OPENAI_API_KEY_HERE",
      "Model": "gpt-4o-mini"
    },
    "Cloudinary": {
      "CloudName": "YOUR_CLOUD_NAME",
      "ApiKey": "YOUR_CLOUDINARY_API_KEY",
      "ApiSecret": "YOUR_CLOUDINARY_API_SECRET"
    }
  }
}
